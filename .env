# Required: Telegram Bot Token
TELEGRAM_BOT_TOKEN=your_token_here

# OPTIONAL: AI API Keys (At least one for real images)
# Get from https://replicate.com (Recommended - fastest)
REPLICATE_API_TOKEN=r8_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OR Get from https://platform.openai.com
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OR Get from https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Bot Settings
BOT_NAME=Pixel Craft Bot
BOT_USERNAME=pixel_craft_bot
BOT_VERSION=3.0.0

# Logging Level
LOG_LEVEL=INFO
